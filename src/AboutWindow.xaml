<Window x:Class="ver10.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О программе"
        Height="300"
        Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="#202020"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border BorderBrush="#828282"
            BorderThickness="1"
            CornerRadius="0"
            Background="#202020">

        <Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#1B1B1B">

                    <Grid>

                        <!-- Кнопка закрытия -->
                        <Button Width="36"
                                Height="36"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,0,0"
                                Click="BtnClose_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid x:Name="grid"
                                          Background="#01000000">

                                        <Image Source="/Resource/close.png"
                                               Width="16"
                                               Height="16"
                                               Stretch="Uniform"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver"
                                                 Value="True">

                                            <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#333333"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed"
                                                 Value="True">

                                            <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#555555"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled"
                                                 Value="False">

                                            <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#222222"/>

                                            <Setter Property="Opacity"
                                                    Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                    </Grid>
                </Border>

                <!-- ОСНОВНОЙ КОНТЕНТ -->
                <Grid Grid.Row="1"
                      Margin="20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Иконка слева -->
                    <Image Grid.Column="0"
                           Width="150"
                           Stretch="Uniform"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="25,5,0,15"
                           Source="/Resource/icon.png"/>

                    <!-- Текст справа -->
                    <StackPanel Grid.Column="1"
                                Margin="5,0,0,15"
                                VerticalAlignment="Center">

                        <TextBlock Text="UNI Convert 1.0"
                                   Foreground="#EAEAEA"
                                   FontFamily="/Assets/Fonts/Baijamjuree/#Bai Jamjuree"
                                   FontWeight="Bold"
                                   FontSize="24"
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock FontSize="14"
                                   Margin="0,0,0,0"
                                   FontFamily="/Assets/Fonts/Inter/#Inter">
                            
                                <Run Text="Лицензия "
                                     Foreground="#B4B4B4"
                                     FontWeight="Regular"/>
    
                                <Hyperlink NavigateUri="https://www.gnu.org/licenses/gpl-3.0.txt"
                                           RequestNavigate="Hyperlink_RequestNavigate"
                                           FontWeight="Regular"
                                           TextDecorations="{x:Null}">
                                    GNU GPL v3.0
                                    <Hyperlink.Style>
                                        <Style TargetType="Hyperlink">
                                            <Setter Property="Foreground" Value="#787878"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#18F0B1"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Hyperlink.Style>
                                </Hyperlink>
                        </TextBlock>

                        <TextBlock FontSize="14"
                                   Margin="0,0,0,0"
                                   FontFamily="/Assets/Fonts/Inter/#Inter">
                            
                                <Run Text="Материал "
                                     Foreground="#B4B4B4"
                                     FontWeight="Regular"/>
    
                                <Hyperlink NavigateUri="https://icons8.com/"
                                           RequestNavigate="Hyperlink_RequestNavigate"
                                           FontWeight="Regular"
                                           TextDecorations="{x:Null}">
                                    www.icons8.com
                                    <Hyperlink.Style>
                                        <Style TargetType="Hyperlink">
                                            <Setter Property="Foreground" Value="#787878"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#18F0B1"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Hyperlink.Style>
                                </Hyperlink>
                        </TextBlock>

                        <TextBlock FontSize="14"
                                   FontFamily="/Assets/Fonts/Inter/#Inter">
                                   
                            <Run Text="Исходник "
                                 Foreground="#B4B4B4"
                                 FontWeight="Regular"/>
    
                            <Hyperlink NavigateUri="https://github.com/benzenergy?tab=repositories"
                                       RequestNavigate="Hyperlink_RequestNavigate"
                                       FontWeight="Regular"
                                       TextDecorations="{x:Null}">
                                www.github.com
                                <Hyperlink.Style>
                                    <Style TargetType="Hyperlink">
                                        <Setter Property="Foreground" Value="#787878"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#18F0B1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Hyperlink.Style>
                            </Hyperlink>
                        </TextBlock>





                        <TextBlock Text="© 2026 benzenergy"
                                   Foreground="Gray"
                                   FontSize="14"
                                   FontFamily="/Assets/Fonts/Inter/#Inter"
                                   FontWeight="Regular"
                                   Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>