<Window
    x:Class="ver10.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="UNI Convert"
    Height="523"
    Width="900"
    WindowStyle="None"
    ResizeMode="CanMinimize"
    Background="#202020"
    WindowStartupLocation="CenterScreen"
    MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="ApplicationCommands.Save"/>
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="ApplicationCommands.SaveAs"/>
    </Window.InputBindings>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resource/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1B1B1B">
            <Grid>
                <Image Source="/Resource/header.png"
                       Height="22"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       HorizontalAlignment="Left"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Width="35"
                            Height="35"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="BtnMinimize_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid x:Name="grid"
                                          Background="#01000000">

                                    <Image Source="/Resource/tray.png"
                                               Width="12"
                                               Height="12"
                                               Stretch="Uniform"/>
                                </Grid>
                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver"
                                                 Value="True">

                                        <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#333333"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed"
                                                 Value="True">

                                        <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#555555"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled"
                                                 Value="False">

                                        <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#222222"/>

                                        <Setter Property="Opacity"
                                                    Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Width="35"
                            Height="35"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="BtnClose_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid x:Name="grid"
                                          Background="#01000000">

                                    <Image Source="/Resource/close.png"
                                               Width="12"
                                               Height="12"
                                               Stretch="Uniform"/>
                                </Grid>
                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver"
                                                 Value="True">

                                        <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#333333"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed"
                                                 Value="True">

                                        <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#555555"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled"
                                                 Value="False">

                                        <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#222222"/>

                                        <Setter Property="Opacity"
                                                    Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!--MAin Window -->
        <ScrollViewer Grid.Row="1" Margin="15"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25px"/>
                    <RowDefinition Height="40px"/>
                    <RowDefinition Height="40px"/>
                    <RowDefinition Height="40px"/>
                    <RowDefinition Height="40px"/>
                    <RowDefinition Height="40px"/>
                    <RowDefinition Height="40px"/>
                    <RowDefinition Height="40px"/>
                    <RowDefinition Height="40px"/>
                    <RowDefinition Height="40px"/>
                    <RowDefinition Height="40px"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Компонент" Grid.Row="0" Grid.Column="0"
                           Foreground="#737373" Margin="0,0,0,5"
                           FontFamily="./assets/fonts/inter/#Inter" FontSize="14px"
                           FontWeight="Regular"/>

                <TextBlock Text="Формула" Grid.Row="0" Grid.Column="1"
                           Foreground="#737373" Margin="10,0,0,5"
                           FontFamily="./assets/fonts/inter/#Inter" FontSize="14px"
                           FontWeight="Regular"/>

                <TextBlock Text="Введите данные" Grid.Row="0" Grid.Column="2"
                           Foreground="#737373" Margin="5,0,0,5"
                           FontFamily="./assets/fonts/inter/#Inter" FontSize="14px"
                           FontWeight="Regular"/>

                <TextBlock Text="Результат" Grid.Row="0" Grid.Column="3"
                           Foreground="#737373" Margin="5,0,0,5"
                           FontFamily="./assets/fonts/inter/#Inter" FontSize="14px"
                           FontWeight="Regular"/>

                <Border Grid.Row="1" Grid.Column="0"
                        Style="{StaticResource ComponentLabelStyle}"
                        Margin="0,0,15,3">

                    <TextBlock Text="Сероводород"
                               
                               Foreground="#A6A6A6"
                               Padding="1" Margin="10,0,0,0"
                               FontFamily="./assets/fonts/inter/#Inter"
                               FontSize="16px"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                </Border>

                <TextBlock Text="H₂S"
                           Grid.Row="1" Grid.Column="1"
                           
                           Foreground="#636363"
                           VerticalAlignment="Center"
                           FontFamily="./assets/fonts/inter/#Inter"
                           FontSize="14px" Margin="10, 0, 0, 0"/>

                <TextBox x:Name="Input1"
                         Grid.Row="1" Grid.Column="2"
                         
                         Padding="8"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource InputTextBoxStyle}"/>

                <TextBox x:Name="Output1"
                         Grid.Row="1" Grid.Column="3"
                         
                         IsReadOnly="True"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource OutputTextBoxGradientStyle}"/>

                <Border Grid.Row="2" Grid.Column="0"
                        Style="{StaticResource ComponentLabelStyle}"
                        Margin="0,2,15,3">

                    <TextBlock Text="Метилмеркаптан"
                               
                               Foreground="#A6A6A6"
                               Padding="1" Margin="10,0,0,0"
                               FontFamily="./assets/fonts/inter/#Inter"
                               FontSize="16px"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                </Border>

                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text="CH₃SH" Foreground="#636363"
                           VerticalAlignment="Center"
                           FontFamily="./assets/fonts/inter/#Inter"
                           FontSize="14px" Margin="10, 0, 0, 0"/>

                <TextBox x:Name="Input2"
                         Grid.Row="2" Grid.Column="2"
                         
                         Padding="8"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource InputTextBoxStyle}"/>

                <TextBox x:Name="Output2"
                         Grid.Row="2" Grid.Column="3"

                         IsReadOnly="True"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource OutputTextBoxGradientStyle}"/>

                <Border Grid.Row="3" Grid.Column="0"
                        Style="{StaticResource ComponentLabelStyle}"
                        Margin="0,2,15,3">

                    <TextBlock Text="Этилмеркаптан"
                               Foreground="#A6A6A6"
                               Padding="1" Margin="10,0,0,0"
                               FontFamily="./assets/fonts/inter/#Inter"
                               FontSize="16px"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                </Border>

                <TextBlock Grid.Row="3" Grid.Column="1" 
                           Text="C₂H₅SH " Foreground="#636363"
                           VerticalAlignment="Center"
                           FontFamily="./assets/fonts/inter/#Inter"
                           FontSize="14px" Margin="10, 0, 0, 0"/>

                <TextBox x:Name="Input3"
                         Grid.Row="3" Grid.Column="2"
                         
                         Padding="8"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource InputTextBoxStyle}"/>

                <TextBox x:Name="Output3" 
                         Grid.Row="3" Grid.Column="3"
                         
                         IsReadOnly="True"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource OutputTextBoxGradientStyle}"/>

                <Border Grid.Row="4" Grid.Column="0"
                        Style="{StaticResource ComponentLabelStyle}"
                        Margin="0,2,15,3">

                    <TextBlock Text="Изопропилмеркаптан"
                               Foreground="#A6A6A6"
                               Padding="1" Margin="10,0,0,0"
                               FontFamily="./assets/fonts/inter/#Inter"
                               FontSize="16px"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                </Border>

                <TextBlock Text="i-C₃H₇SH"
                           Grid.Row="4" Grid.Column="1"

                           Foreground="#636363"
                           VerticalAlignment="Center"
                           FontFamily="./assets/fonts/inter/#Inter"
                           FontSize="14px"
                           Margin="10, 0, 0, 0"/>

                <TextBox x:Name="Input4"
                         Grid.Row="4" Grid.Column="2"
                         
                         Padding="8"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource InputTextBoxStyle}"/>

                <TextBox x:Name="Output4"
                         Grid.Row="4" Grid.Column="3"
                         
                         IsReadOnly="True"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource OutputTextBoxGradientStyle}"/>

                <Border Grid.Row="5" Grid.Column="0"
                        Style="{StaticResource ComponentLabelStyle}"
                        Margin="0,2,15,3">

                    <TextBlock Text="Пропилмеркаптан"
                               Foreground="#A6A6A6"
                               Padding="1" Margin="10,0,0,0"
                               FontFamily="./assets/fonts/inter/#Inter"
                               FontSize="16px"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                </Border>

                <TextBlock Grid.Row="5" Grid.Column="1"
                           Text="C₃H₇SH" Foreground="#636363"
                           VerticalAlignment="Center"
                           FontFamily="./assets/fonts/inter/#Inter"
                           FontSize="14px" Margin="10, 0, 0, 0"/>

                <TextBox x:Name="Input5"
                         Grid.Row="5" Grid.Column="2"
                         
                         Padding="8"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource InputTextBoxStyle}"/>

                <TextBox x:Name="Output5"
                         Grid.Row="5" Grid.Column="3"

                         IsReadOnly="True"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource OutputTextBoxGradientStyle}"/>

                <Border Grid.Row="6" Grid.Column="0"
                        Style="{StaticResource ComponentLabelStyle}"
                        Margin="0,2,15,3">

                    <TextBlock Text="трет-Бутилмеркаптан"
                               Foreground="#A6A6A6"
                               Padding="1" Margin="10,0,0,0"
                               FontFamily="./assets/fonts/inter/#Inter"
                               FontSize="16px"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                </Border>

                <TextBlock Grid.Row="6" Grid.Column="1"
                           Text="трет-C₄H₉SH" Foreground="#636363"
                           VerticalAlignment="Center"
                           FontFamily="./assets/fonts/inter/#Inter"
                           FontSize="14px" Margin="10, 0, 0, 0"/>

                <TextBox x:Name="Input6"
                         Grid.Row="6" Grid.Column="2" 
                         
                         Padding="8"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource InputTextBoxStyle}"/>

                <TextBox x:Name="Output6"
                         Grid.Row="6" Grid.Column="3"
                         
                         IsReadOnly="True"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource OutputTextBoxGradientStyle}"/>

                <Border Grid.Row="7" Grid.Column="0"
                        Style="{StaticResource ComponentLabelStyle}"
                        Margin="0,2,15,3">

                    <TextBlock Text="втор-Бутилмеркаптан"
                               Foreground="#A6A6A6"
                               Padding="1" Margin="10,0,0,0"
                               FontFamily="./assets/fonts/inter/#Inter"
                               FontSize="16px"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                </Border>

                <TextBlock Grid.Row="7" Grid.Column="1"
                           Text="втор-C₄H₉SH" Foreground="#636363"
                           VerticalAlignment="Center"
                           FontFamily="./assets/fonts/inter/#Inter"
                           FontSize="14px" Margin="10, 0, 0, 0"/>

                <TextBox x:Name="Input7" 
                         Grid.Row="7" Grid.Column="2" 
                         
                         Padding="8"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource InputTextBoxStyle}"/>

                <TextBox x:Name="Output7"
                         Grid.Row="7" Grid.Column="3"
                         
                         IsReadOnly="True"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource OutputTextBoxGradientStyle}"/>

                <Border Grid.Row="8" Grid.Column="0"
                        Style="{StaticResource ComponentLabelStyle}"
                        Margin="0,2,15,3">

                    <TextBlock Text="Изобутилмеркаптан"
                               Foreground="#A6A6A6"
                               Padding="1" Margin="10,0,0,0"
                               FontFamily="./assets/fonts/inter/#Inter"
                               FontSize="16px"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                </Border>

                <TextBlock Grid.Row="8" Grid.Column="1"
                           Text="i-C₄H₉SH" Foreground="#636363"
                           VerticalAlignment="Center"
                           FontFamily="./assets/fonts/inter/#Inter"
                           FontSize="14px" Margin="10, 0, 0, 0"/>

                <TextBox x:Name="Input8" 
                         Grid.Row="8" Grid.Column="2"
                         
                         Padding="8"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource InputTextBoxStyle}"/>

                <TextBox x:Name="Output8"
                         Grid.Row="8" Grid.Column="3"
                         
                         IsReadOnly="True"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource OutputTextBoxGradientStyle}"/>

                <Border Grid.Row="9" Grid.Column="0"
                        Style="{StaticResource ComponentLabelStyle}"
                        Margin="0,2,15,3">

                    <TextBlock Text="Бутантиолбутилмеркаптан" 
                               Foreground="#A6A6A6"
                               Padding="1" Margin="10,0,0,0"
                               FontFamily="./assets/fonts/inter/#Inter"
                               FontSize="16"
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Left"/>
                </Border>

                <TextBlock Grid.Row="9"
                           Grid.Column="1"
                           Text="C₄H₉SH"
                           Foreground="#636363"
                           VerticalAlignment="Center"
                           FontFamily="./assets/fonts/inter/#Inter"
                           FontSize="14px"
                           Margin="10, 0, 0, 0"/>

                <TextBox x:Name="Input9"
                         Grid.Row="9" Grid.Column="2"

                         Padding="8"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource InputTextBoxStyle}"/>

                <TextBox x:Name="Output9"
                         Grid.Row="9" Grid.Column="3"

                         IsReadOnly="True"
                         Margin="5, 2, 5, 2"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource OutputTextBoxGradientStyle}"/>

                <Border Grid.Row="10" Grid.Column="0"
                        BorderBrush="#535353"
                        Background="#242424"
                        BorderThickness="1"
                        CornerRadius="5"
                        Width="303"
                        Height="37"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">

                    <TextBlock FontFamily="./assets/fonts/inter/#Inter"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="7,0,0,0">

                        <Run Text="Метод конвертации: "
                             Foreground="#636363"/>

                        <InlineUIContainer>
                            <TextBlock x:Name="MethodText"
                                       Text="ppm → мг/м³"
                                       FontFamily="./assets/fonts/inter/#Inter"
                                       FontSize="16"
                                       VerticalAlignment="Center">

                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#66EA4F" Offset="0"/>
                                        <GradientStop Color="#18F0B1" Offset="0.5"/>
                                        <GradientStop Color="#02C4F8" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>

                            </TextBlock>
                        </InlineUIContainer>

                    </TextBlock>
                </Border>

                <Button Grid.Row="10" Grid.Column="2"
                    x:Name="SettingsButton"
                    Content="Настройки"
                    FontSize="16px"
                    FontFamily="/Assets/Fonts/#Inter"
                    FontWeight="SemiBold"
                    Style="{StaticResource SettingsButtonStyle}"
                    Width="Auto"
                    Height="Auto"
                    Padding="8"
                    Margin="5, 2, 5, 2"
                    VerticalContentAlignment="Center"
                    Click="SettingsButton_Click"/>

                <Button Grid.Row="10" Grid.Column="3"
                    x:Name="CalculateButton"
                    Content="Рассчитать"
                    FontSize="16px"
                    FontFamily="/Assets/Fonts/#Inter"
                    FontWeight="SemiBold"
                    Style="{StaticResource CalculateButtonStyle}"
                    Width="Auto"
                    Height="Auto"
                    Padding="8"
                    Margin="5, 2, 5, 2"
                    VerticalContentAlignment="Center"
                    Click="CalculateButton_Click">

                    <Button.Foreground>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#66EA4F" Offset="0"/>
                            <GradientStop Color="#18F0B1" Offset="0.5"/>
                            <GradientStop Color="#02C4F8" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Foreground>
                </Button>

            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <DockPanel Grid.Row="3"
                   Background="#1B1B1B"
                   LastChildFill="False"
                   Height="33">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="10,0">

                <Button x:Name="FileButton"
                        Style="{StaticResource TextButtonStyle}"
                        Content="Файл"
                        Margin="5,0,20,0"
                        Click="FileButton_Click"/>

                <Button Content="Справка"
                        Style="{StaticResource TextButtonStyle}"
                        Click="AboutButton_Click"/>

            </StackPanel>

            <Popup x:Name="FilePopup"
                   Placement="Top"
                   PlacementTarget="{Binding ElementName=FileButton}"
                   StaysOpen="False"
                   AllowsTransparency="True">

                <Border Background="#101010"
                        BorderBrush="#3C3C3C"
                        BorderThickness="1"
                        CornerRadius="0"
                        Padding="5">

                    <StackPanel Width="320"
                                Height="Auto">

                        <!-- Excel -->
                        <Button Style="{StaticResource PopupMenuButtonStyle}"
                                Click="SaveAsExcel_Click">

                            <StackPanel Orientation="Horizontal">
                                <Image Source="Assets/Icons/excel.png"
                                       Width="24"
                                       Height="Auto"
                                       Margin="0,0,10,0"/>

                                <TextBlock Text="Сохранить как Excel"
                                           FontSize="14px"/>

                                <TextBlock Text="Ctrl+S"
                                           Foreground="#888888"
                                           FontSize="14px"
                                           VerticalAlignment="Center"
                                           Margin="30,0,0,0"/>
                            </StackPanel>

                        </Button>

                        <!-- PDF -->
                        <Button Style="{StaticResource PopupMenuButtonStyle}"
                                Click="SaveAsPDF_Click">

                            <StackPanel Orientation="Horizontal">
                                <Image Source="Assets/Icons/pdf.png"
                                       Width="24"
                                       Height="Auto"
                                       Margin="0,0,10,0"/>

                                <TextBlock Text="Сохранить как PDF"
                                           FontSize="14px"/>

                                <TextBlock Text=" Ctrl+Shift+S"
                                           Foreground="#888888"
                                           FontSize="14px"
                                           VerticalAlignment="Center"
                                           Margin="30,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>
        </DockPanel>
    </Grid>
</Window>