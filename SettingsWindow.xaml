<Window x:Class="ver10.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Width="450" Height="250"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resource/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Стиль серого разделителя -->
            <Style TargetType="Separator">
                <Setter Property="Margin" Value="5,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Separator">
                            <Border Height="1"
                                Background="#666666"
                                Margin="5,2"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    
    <Border BorderBrush="#1B1B1B"
            BorderThickness="1"
            Background="#FFFFFF">

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0"
                  Background="#1B1B1B">

                <TextBlock Text="Настройки"
                           Foreground="#8F8F8F"
                           VerticalAlignment="Center"
                           FontFamily="/Assets/Fonts/#Inter"
                           FontWeight="Regular"
                           FontSize="12"
                           Margin="10,0,0,0"/>

                <!-- Кнопка закрытия -->
                <Button Width="35"
                            Height="35"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="BtnClose_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="grid"
                                          Background="#01000000">

                                <Image Source="/Resource/close.png"
                                               Width="12"
                                               Height="12"
                                               Stretch="Uniform"/>
                            </Grid>
                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver"
                                                 Value="True">

                                    <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#333333"/>
                                </Trigger>
                                <Trigger Property="IsPressed"
                                                 Value="True">

                                    <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#555555"/>
                                </Trigger>
                                <Trigger Property="IsEnabled"
                                                 Value="False">

                                    <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#222222"/>

                                    <Setter Property="Opacity"
                                                    Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Label -->
            <TextBlock Grid.Row="1"
                       Text="Метод конвертации"
                       Foreground="#373737"
                       FontSize="16"
                       FontFamily="/Assets/Fonts/#Inter"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0, 50, 0, 10"/>

            <!-- ComboBox -->
            <ComboBox x:Name="ConversionComboBox"
                      Grid.Row="2"
                      Height="35"
                      Width="250"
                      Cursor="Hand"
                      Margin="0,0,0,10"
                      Foreground="White"
                      ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                      Style="{StaticResource OutputComboBoxStyle}">

                <ComboBoxItem Content="ppm → mg/m³"/>
                <ComboBoxItem Content="mg/m³ → ppm"/>

                <ComboBoxItem IsEnabled="False"
                              Focusable="False"
                              Padding="0"
                              Background="Transparent"
                              HorizontalContentAlignment="Stretch">

                    <Grid>
                        <Rectangle Height="1"
                                   Fill="#373737"
                                   HorizontalAlignment="Stretch"
                                   Margin="0"/>
                    </Grid>

                </ComboBoxItem>

                <ComboBoxItem Content="% об. → mg/m³"/>
                <ComboBoxItem Content="mg/m³ → % об."/>

                <ComboBoxItem IsEnabled="False"
                              Focusable="False"
                              Padding="0"
                              Background="Transparent"
                              HorizontalContentAlignment="Stretch">

                    <Grid>
                        <Rectangle Height="1"
                                   Fill="#373737"
                                   HorizontalAlignment="Stretch"
                                   Margin="0"/>
                    </Grid>

                </ComboBoxItem>

                <ComboBoxItem Content="ppm → % об."/>
                <ComboBoxItem Content="% об. → ppm"/>

            </ComboBox>

            <!-- Button Save -->
            <Button Grid.Row="3"
                    Style="{StaticResource SettingsSaveStyle}"
                    Content="Сохранить"
                    Height="35" Width="140"
                    Margin="0, 0, 0, 20"
                    Foreground="White"
                    FontFamily="/Assets/Fonts/#Inter"
                    FontWeight="Regular"
                    FontSize="14"
                    Click="BtnSave_Click"
                    />
        </Grid>
    </Border>
</Window>